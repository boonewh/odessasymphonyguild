      {/* Print-only header */}
      <div className="hidden print:block fixed top-0 left-0 w-full p-4 text-center border-b">
        <h1 className="text-xl font-bold">
          OSG Belles &amp; Beaux — {BELLES_BEAUX_CONFIG.schoolYear} Roster
